module Test where

import Daml.Script
import DA.Assert
import DA.List (head)
import PqcConfidentialPayload

-- Real ciphertext from core_kms's HybridCipher (X25519 + ML-KEM-768), via
-- anvil_pqc_adapter/cli, encrypting "settlement amount: 50000 USD,
-- instrument ISIN US0378331005".
testEphemeralXPubHex : Text
testEphemeralXPubHex = "302a300506032b656e0321000a3fb7bbf2dd2c5f8a3cc00899d5df48f2e461866a19870d7a87c08429047c43"

testKemEncapsulationHex : Text
testKemEncapsulationHex = ""

testNonceHex : Text
testNonceHex = "3338a5278c02db780ab22c75"

testAesCiphertextHex : Text
testAesCiphertextHex = "ed0831211f8a01ecf0b2e28986a53f2ac9a011c3f05467334a75bc343bd0f6d0123fe459a9ef1a290efd4511778cd4e84baf38de2615adbd1d8924e959560e75767aae776f442c4b588b"

-- Proves two things:
--  1. The contract carries real core_kms-produced ciphertext correctly.
--  2. Canton's privacy model means a third, uninvolved party never even
--     receives this contract (unlike the Anvil version, where the bytes
--     are publicly visible to anyone watching the chain).
test_confidentialPayload : Script ()
test_confidentialPayload = do
  sender <- allocateParty "Sender"
  recipient <- allocateParty "Recipient"
  thirdParty <- allocateParty "ThirdParty"

  cid <- submit sender do
    createCmd PqcConfidentialPayload with
      sender = sender
      recipient = recipient
      ephemeralXPubHex = testEphemeralXPubHex
      kemEncapsulationHex = testKemEncapsulationHex
      nonceHex = testNonceHex
      aesCiphertextHex = testAesCiphertextHex

  recipientView <- query @PqcConfidentialPayload recipient
  length recipientView === 1

  thirdPartyView <- query @PqcConfidentialPayload thirdParty
  length thirdPartyView === 0

  -- Sanity-check the fields the recipient sees match what was sent.
  let (_, payload) = head recipientView
  payload.aesCiphertextHex === testAesCiphertextHex
  payload.nonceHex === testNonceHex

  -- Recipient archives after decrypting off-ledger via core_kms.
  submit recipient do
    exerciseCmd cid Acknowledge

  pure ()
